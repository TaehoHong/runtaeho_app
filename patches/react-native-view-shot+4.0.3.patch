+    private void applyAncestorClipping(@NonNull final Canvas c, @NonNull final View view, final boolean isChild) {
+        if (isChild || !(view instanceof ViewGroup)) {
+            return;
+        }
+
+        final ViewGroup viewGroup = (ViewGroup) view;
+        final boolean clipChildren = viewGroup.getClipChildren();
+        final boolean clipToPadding = viewGroup.getClipToPadding();
+        if (!clipChildren && !clipToPadding) {
+            return;
+        }
+
+        final int clipLeft = clipToPadding ? viewGroup.getPaddingLeft() : 0;
+        final int clipTop = clipToPadding ? viewGroup.getPaddingTop() : 0;
+        final int clipRight = clipToPadding
+                ? viewGroup.getWidth() - viewGroup.getPaddingRight()
+                : viewGroup.getWidth();
+        final int clipBottom = clipToPadding
+                ? viewGroup.getHeight() - viewGroup.getPaddingBottom()
+                : viewGroup.getHeight();
+
+        if (clipRight > clipLeft && clipBottom > clipTop) {
+            c.clipRect(clipLeft, clipTop, clipRight, clipBottom);
+        }
+    }
